# Server Configuration
PORT=4010
CLIENT_URL=http://localhost:3010
DATABASE_URL="postgresql://user:password@localhost:5432/fbst"

# Auth Configuration (Required)
# ------------------------------------------------------------------
# Get these from Google Cloud Console & Yahoo Developer Portal
# ------------------------------------------------------------------

# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Leave GOOGLE_REDIRECT_URI empty for local dev (auto-detected: http://localhost:3010/api/auth/google/callback)
# Set explicitly for production (https://fbst-api.onrender.com/api/auth/google/callback)
GOOGLE_REDIRECT_URI=

# Yahoo
YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
# Leave YAHOO_REDIRECT_URI empty for local dev (auto-detected: https://localhost:4000/api/auth/yahoo/callback)
# Set explicitly for production
YAHOO_REDIRECT_URI=

# Session Security
# Generate a strong random string for production
SESSION_SECRET=super_secret_session_key_DO_NOT_USE_IN_PROD

# HMAC key for session-tracking IP hashing (UserSession.ipHash).
# Must be at least 32 chars. Generate with: openssl rand -hex 32
IP_HASH_SECRET=replace_with_openssl_rand_hex_32_at_least_32_chars_long

# Environment
NODE_ENV=development
