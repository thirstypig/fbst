// prisma/schema.prisma

// ======================
//  Datasource + Generator
// ======================
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../server/node_modules/.prisma/client"
}

// ======================
//  Enums
// ======================

enum DraftMode {
  AUCTION
  DRAFT
}

enum DraftOrder {
  SNAKE
  LINEAR
}

// NEW: League roles for access control
enum LeagueRole {
  COMMISSIONER
  OWNER
}

enum TradeStatus {
  PROPOSED
  ACCEPTED
  REJECTED
  VETOED
  PROCESSED
  CANCELLED
  REVERSED
}

enum AssetType {
  PLAYER
  BUDGET
  PICK
  FUTURE_BUDGET
  WAIVER_PRIORITY
}

enum ClaimStatus {
  PENDING
  SUCCESS
  FAILED_OUTBID
  FAILED_INVALID
  FAILED_CONDITION
  CANCELLED
}

enum SeasonStatus {
  SETUP
  DRAFT
  IN_SEASON
  COMPLETED
}

// ======================
//  Models
// ======================

model Franchise {
  id                 Int       @id @default(autoincrement())
  name               String    @unique
  isPublic           Boolean   @default(false)
  publicSlug         String?   @unique
  inviteCode         String?   @unique
  tradeReviewPolicy  String    @default("COMMISSIONER")
  vetoThreshold      Int       @default(4)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  leagues      League[]
  memberships  FranchiseMembership[]
}

model FranchiseMembership {
  id           Int        @id @default(autoincrement())
  franchiseId  Int
  userId       Int
  role         LeagueRole
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  franchise  Franchise @relation(fields: [franchiseId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([franchiseId, userId])
  @@index([userId])
  @@index([franchiseId])
}

model User {
  id           Int     @id @default(autoincrement())
  email        String  @unique
  name         String?
  avatarUrl    String?
  googleSub    String? @unique
  yahooSub     String? @unique
  passwordHash String?

  resetToken        String?   @unique
  resetTokenExpires DateTime?

  venmoHandle  String?
  zelleHandle  String?
  paypalHandle String?

  isAdmin Boolean @default(false)

  memberships            LeagueMembership[]
  franchiseMemberships   FranchiseMembership[]
  ownedTeams             Team[]             @relation("TeamOwner")
  teamOwnerships         TeamOwnership[]
  auditLogs              AuditLog[]
  boardCards             BoardCard[]
  boardReplies           BoardCardReply[]
  productBoardCards      ProductBoardCard[]  @relation("ProductBoardCards")
  productBoardReplies    ProductBoardReply[] @relation("ProductBoardReplies")

  pushSubscriptions      PushSubscription[]
  notificationPreference NotificationPreference?
  chatMessages           ChatMessage[]
  profile                UserProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProfile {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  bio             String?  @db.VarChar(200)
  favoriteTeam    String?  // MLB team abbreviation (e.g. "LAD", "NYY")
  experienceLevel String?  // "1-3", "3-5", "5-10", "10+"
  preferredFormats String[] @default([]) // ["ROTO", "H2H", "KEEPER", "DYNASTY", "POINTS"]
  paymentHandles  Json?    // { venmo?: string, paypal?: string, zelle?: string, cashapp?: string }
  timezone        String?  // IANA timezone (e.g. "America/Los_Angeles")
  isPublic        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model League {
  id         Int         @id @default(autoincrement())
  name       String
  season     Int
  draftMode  DraftMode
  draftOrder DraftOrder?
  createdAt  DateTime    @default(now())

  // Sport type — "baseball", "football", "basketball"
  sport      String      @default("baseball")

  isPublic   Boolean @default(false)
  publicSlug String? @unique
  inviteCode String? @unique

  // Scoring Format (ROTO default protects existing leagues like OGBA)
  scoringFormat      String @default("ROTO")  // "ROTO" | "H2H_CATEGORIES" | "H2H_POINTS"
  pointsConfig       Json?  // Points scoring weights: { "R": 1, "HR": 4, "RBI": 1, "SB": 2, ... }
  playoffWeeks       Int    @default(3)
  playoffTeams       Int    @default(4)
  regularSeasonWeeks Int    @default(20)

  // Trade Settings
  tradeReviewPolicy String @default("COMMISSIONER") // COMMISSIONER, LEAGUE_VOTE
  vetoThreshold     Int    @default(4)

  // Waiver Configuration
  waiverType        String  @default("FAAB")           // FAAB, ROLLING_PRIORITY, REVERSE_STANDINGS, FREE_AGENT
  faabBudget        Int     @default(200)
  faabMinBid        Int     @default(0)
  waiverPeriodDays  Int     @default(2)
  processingFreq    String  @default("DAILY")           // DAILY, WEEKLY_WED, WEEKLY_SUN, etc.
  faabTiebreaker    String  @default("ROLLING_PRIORITY") // ROLLING_PRIORITY, REVERSE_STANDINGS, RANDOM
  acquisitionLimit  Int?                                 // null = unlimited
  conditionalClaims Boolean @default(true)
  tradeDeadline     DateTime?
  rosterLockTime    String? // "GAME_TIME" or "DAILY_LOCK"

  // League Discovery & Capacity
  visibility  String  @default("PRIVATE") // PRIVATE, PUBLIC, OPEN
  maxTeams    Int     @default(12)
  description String? @db.Text
  entryFee    Float?
  entryFeeNote String?

  // Franchise FK (org-level parent)
  franchiseId  Int
  franchise    Franchise @relation(fields: [franchiseId], references: [id])

  teams             Team[]
  memberships       LeagueMembership[]
  transactions      TransactionEvent[]
  historicalSeasons HistoricalSeason[]
  rules             LeagueRule[]
  trades            Trade[]
  seasons           Season[]
  periods           Period[]
  auctionSession    AuctionSession?
  snakeDraftSession SnakeDraftSession?
  draftPicks        DraftPick[]
  matchups          Matchup[]
  invites           LeagueInvite[]
  playerValues      PlayerValue[]
  aiInsights        AiInsight[]
  boardCards        BoardCard[]
  chatMessages      ChatMessage[]

  @@unique([name, season])
}

// Dynamic Rules Management
model LeagueRule {
  id       Int    @id @default(autoincrement())
  leagueId Int
  league   League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  category String // "overview", "roster", "scoring", "draft", "trades", "bonuses", "payouts"
  key      String // "team_count", "budget", "keeper_count", etc.
  value    String // JSON string for complex values
  label    String // Display label for UI

  isLocked Boolean @default(false) // Locked after season start

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leagueId, category, key])
  @@index([leagueId])
}

model LeagueMembership {
  id       Int        @id @default(autoincrement())
  leagueId Int
  userId   Int
  role     LeagueRole

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([leagueId, userId])
  @@index([userId])
  @@index([leagueId])
  @@index([leagueId, role])
}

// Multi-owner support (up to 2 owners per team)
model TeamOwnership {
  id     Int @id @default(autoincrement())
  teamId Int
  userId Int

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

model Team {
  id        Int      @id @default(autoincrement())
  leagueId  Int
  name      String
  owner     String?
  budget    Int      @default(400)
  createdAt DateTime @default(now())

  code        String?
  ownerUserId Int?
  ownerUser   User?   @relation("TeamOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  // Multi-owner support
  ownerships TeamOwnership[]

  // Link to prior year team for historical tracking
  priorTeamId Int?
  priorTeam   Team?  @relation("TeamHistory", fields: [priorTeamId], references: [id], onDelete: SetNull)
  nextTeams   Team[] @relation("TeamHistory")

  league        League            @relation(fields: [leagueId], references: [id])
  rosters       Roster[]
  stats         TeamStatsPeriod[]
  season        TeamStatsSeason?
  financeEvents FinanceLedger[]

  // ADD THIS:
  transactions TransactionEvent[]
  auctionBids  AuctionBid[]

  // Waiver priority override (commissioner-set; overrides computed standings-based rank)
  waiverPriorityOverride Int?

  // Trade Block: JSON array of playerIds the owner has flagged as available for trade
  tradeBlockPlayerIds Json @default("[]")

  // Trade Relations
  proposedTrades     Trade[]     @relation("TradeProposer")
  tradeItemsSent     TradeItem[] @relation("TradeSender")
  tradeItemsReceived TradeItem[] @relation("TradeRecipient")

  // Waiver Relations
  waiverClaims WaiverClaim[]

  // AI Insights
  aiInsights AiInsight[]

  // Watchlist + Trading Block
  watchlist     Watchlist[]
  tradingBlock  TradingBlock[]

  // Snake Draft + H2H Matchups
  draftPicks    DraftPick[]
  matchupsAsA   Matchup[]   @relation("matchupTeamA")
  matchupsAsB   Matchup[]   @relation("matchupTeamB")

  @@unique([leagueId, name])
  @@unique([leagueId, code])
  @@index([leagueId])
  @@index([ownerUserId])
}

model Player {
  id Int @id @default(autoincrement())

  // Canonical internal integration key (do not expose to UI).
  // Keep nullable for now to avoid breaking existing rows; Postgres UNIQUE allows many NULLs.
  mlbId Int? @unique

  name       String
  posPrimary String
  posList    String // comma-separated for now
  mlbTeam    String? // e.g. "LAD", "NYY"

  createdAt DateTime @default(now())

  rosters          Roster[]
  lots             AuctionLot[]
  aliases          PlayerAlias[]
  transactions     TransactionEvent[]
  tradeItems       TradeItem[]
  waiverClaimsAdd       WaiverClaim[]      @relation("ClaimAdd")
  waiverClaimsDrop      WaiverClaim[]      @relation("ClaimDrop")
  waiverClaimsCondition WaiverClaim[]      @relation("ClaimCondition")
  periodStats      PlayerStatsPeriod[]
  dailyStats       PlayerStatsDaily[]
  playerValues     PlayerValue[]
  draftPicks       DraftPick[]
  watchlistEntries Watchlist[]
  tradingBlockEntries TradingBlock[]

  @@index([name])
}

model PlayerAlias {
  id       Int @id @default(autoincrement())
  playerId Int

  // e.g. "onroto"
  source String

  // e.g. "NArenado", "HyeKim"
  alias String

  createdAt DateTime @default(now())

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([source, alias])
  @@index([playerId])
  @@index([alias])
}

model TransactionEvent {
  id Int @id @default(autoincrement())

  // Your parser’s idempotency key (md5 over raw fields)
  rowHash String @unique

  leagueId Int
  season   Int

  // Best-effort parsed timestamps
  effDate     DateTime?
  submittedAt DateTime?

  // Raw strings from HTML (keep them for traceability/debugging)
  effDateRaw     String?
  submittedRaw   String?
  ogbaTeamName   String?
  playerAliasRaw String?
  mlbTeamAbbr    String?
  transactionRaw String?

  // Normalized “types” (optional, but useful)
  transactionType String?
  toPosition      String?

  // Joins (optional until mapped)
  teamId   Int?
  playerId Int?

  createdAt DateTime @default(now())

  league League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team   Team?   @relation(fields: [teamId], references: [id], onDelete: SetNull)
  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@index([leagueId, season])
  @@index([teamId])
  @@index([playerId])
  @@index([submittedAt])
  @@index([leagueId, submittedAt])
}

model Season {
  id        Int          @id @default(autoincrement())
  leagueId  Int
  year      Int
  status    SeasonStatus @default(SETUP)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  league  League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  periods Period[]

  @@unique([leagueId, year])
  @@index([leagueId])
  @@index([leagueId, status])
}

model Period {
  id        Int      @id @default(autoincrement())
  name      String
  startDate DateTime
  endDate   DateTime
  status    String

  leagueId  Int?
  seasonId  Int?

  league    League?  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  season    Season?  @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  teamStats   TeamStatsPeriod[]
  playerStats PlayerStatsPeriod[]
  matchups    Matchup[]

  @@unique([seasonId, name])
  @@index([leagueId])
  @@index([seasonId])
  @@index([leagueId, status])
}

model TeamStatsPeriod {
  id       Int @id @default(autoincrement())
  teamId   Int
  periodId Int

  // Batting
  R   Int   @default(0)
  HR  Int   @default(0)
  RBI Int   @default(0)
  SB  Int   @default(0)
  AVG Float @default(0)

  // Pitching
  W    Int   @default(0)
  S    Int   @default(0) // saves
  ERA  Float @default(0)
  WHIP Float @default(0)
  K    Int   @default(0)

  // Misc
  gamesPlayed Int @default(0)

  team   Team   @relation(fields: [teamId], references: [id])
  period Period @relation(fields: [periodId], references: [id])

  @@unique([teamId, periodId])
}

/// @deprecated Use TeamStatsPeriod aggregation instead. Table left in DB for backward compat; no code reads this.
model TeamStatsSeason {
  id     Int @id @default(autoincrement())
  teamId Int @unique

  // Batting
  R   Int   @default(0)
  HR  Int   @default(0)
  RBI Int   @default(0)
  SB  Int   @default(0)
  AVG Float @default(0)

  // Pitching
  W    Int   @default(0)
  S    Int   @default(0)
  ERA  Float @default(0)
  WHIP Float @default(0)
  K    Int   @default(0)

  gamesPlayed Int @default(0)

  team Team @relation(fields: [teamId], references: [id])
}

model PlayerStatsPeriod {
  id       Int @id @default(autoincrement())
  playerId Int
  periodId Int

  // Batting
  AB  Int @default(0)
  H   Int @default(0)
  R   Int @default(0)
  HR  Int @default(0)
  RBI Int @default(0)
  SB  Int @default(0)

  // Pitching
  W    Int   @default(0)
  SV   Int   @default(0)
  K    Int   @default(0)
  IP   Float @default(0)
  ER   Int   @default(0)
  BB_H Int   @default(0) // walks + hits allowed (for WHIP)

  player Player @relation(fields: [playerId], references: [id])
  period Period @relation(fields: [periodId], references: [id])

  @@unique([playerId, periodId])
  @@index([periodId])
}

model PlayerStatsDaily {
  id       Int      @id @default(autoincrement())
  playerId Int
  gameDate DateTime @db.Date

  // Batting
  AB  Int @default(0)
  H   Int @default(0)
  R   Int @default(0)
  HR  Int @default(0)
  RBI Int @default(0)
  SB  Int @default(0)

  // Pitching
  W    Int   @default(0)
  SV   Int   @default(0)
  K    Int   @default(0)
  IP   Float @default(0)
  ER   Int   @default(0)
  BB_H Int   @default(0) // walks + hits allowed (for WHIP)

  player Player @relation(fields: [playerId], references: [id])

  @@unique([playerId, gameDate])
  @@index([gameDate])
  @@index([playerId, gameDate])
}

model Roster {
  id               Int       @id @default(autoincrement())
  teamId           Int
  playerId         Int
  acquiredAt       DateTime  @default(now())
  releasedAt       DateTime?
  source           String
  price            Int       @default(1)
  assignedPosition String?
  isKeeper         Boolean   @default(false)

  team   Team   @relation(fields: [teamId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@index([teamId])
  @@index([playerId])
  @@index([teamId, releasedAt])
  @@index([releasedAt, playerId])
}

model AuctionLot {
  id               Int       @id @default(autoincrement())
  playerId         Int
  nominatingTeamId Int
  status           String
  startTs          DateTime  @default(now())
  endTs            DateTime?
  finalPrice       Int?
  winnerTeamId     Int?

  player Player @relation(fields: [playerId], references: [id])

  bids AuctionBid[]

  @@index([playerId])
}

model AuctionBid {
  id     Int      @id @default(autoincrement())
  lotId  Int
  teamId Int
  amount Int
  ts     DateTime @default(now())

  lot  AuctionLot @relation(fields: [lotId], references: [id], onDelete: Cascade)
  team Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([lotId])
  @@index([teamId])
}

model FinanceLedger {
  id     Int      @id @default(autoincrement())
  teamId Int
  type   String // entry_fee, bonus, il_fee, auction_adjust, etc.
  amount Int
  reason String?
  ts     DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id])

  @@index([teamId])
}

// ======================
//  Trade & Waiver System
// ======================

model Trade {
  id          Int         @id @default(autoincrement())
  leagueId    Int
  proposerId  Int
  status      TradeStatus @default(PROPOSED)
  createdAt   DateTime    @default(now())
  expiresAt   DateTime?
  processedAt DateTime?
  aiAnalysis  Json?

  items TradeItem[]

  league   League @relation(fields: [leagueId], references: [id])
  proposer Team   @relation("TradeProposer", fields: [proposerId], references: [id])

  @@index([leagueId])
  @@index([proposerId])
  @@index([status])
  @@index([leagueId, status])
}

model TradeItem {
  id          Int       @id @default(autoincrement())
  tradeId     Int
  senderId    Int
  recipientId Int
  assetType   AssetType @default(PLAYER)

  // Asset References
  playerId  Int? // If PLAYER
  amount    Int? // If BUDGET, PICK (round), or FUTURE_BUDGET ($)
  pickRound Int? // If PICK
  season    Int? // If PICK or FUTURE_BUDGET: which season it applies to

  trade     Trade   @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  sender    Team    @relation("TradeSender", fields: [senderId], references: [id])
  recipient Team    @relation("TradeRecipient", fields: [recipientId], references: [id])
  player    Player? @relation(fields: [playerId], references: [id])

  @@index([tradeId])
  @@index([senderId])
  @@index([recipientId])
}

model WaiverClaim {
  id           Int         @id @default(autoincrement())
  teamId       Int
  playerId     Int // Player to ADD
  dropPlayerId Int? // Player to DROP (optional)
  bidAmount    Int // FAAB $
  priority     Int // User-defined order
  status       ClaimStatus @default(PENDING)
  processedAt  DateTime?
  createdAt    DateTime    @default(now())
  aiAnalysis   Json?

  // Conditional claim fields
  conditionType      String?  // "ONLY_IF_UNAVAILABLE", "ONLY_IF_AVAILABLE", "PAIR_WITH"
  conditionPlayerId  Int?     // the player the condition references
  conditionNote      String?  // human-readable condition description

  team            Team    @relation(fields: [teamId], references: [id])
  player          Player  @relation("ClaimAdd", fields: [playerId], references: [id])
  dropPlayer      Player? @relation("ClaimDrop", fields: [dropPlayerId], references: [id])
  conditionPlayer Player? @relation("ClaimCondition", fields: [conditionPlayerId], references: [id])

  @@index([teamId])
  @@index([status])
}

// ======================
//  Historical Archive Models
// ======================

model HistoricalSeason {
  id       Int     @id @default(autoincrement())
  year     Int // e.g., 2024, 2023
  leagueId Int?
  league   League? @relation(fields: [leagueId], references: [id])

  periods   HistoricalPeriod[]
  standings HistoricalStanding[]

  createdAt DateTime @default(now())

  @@unique([year, leagueId])
  @@index([year])
}

model HistoricalPeriod {
  id           Int              @id @default(autoincrement())
  seasonId     Int
  season       HistoricalSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  periodNumber Int // 1-6
  startDate    DateTime?
  endDate      DateTime?

  stats HistoricalPlayerStat[]

  @@unique([seasonId, periodNumber])
  @@index([seasonId])
}

model HistoricalPlayerStat {
  id       Int              @id @default(autoincrement())
  periodId Int
  period   HistoricalPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  playerName String
  fullName   String? // Full display name - commissioner can override

  mlbId     String?
  teamCode  String // OGBA team code
  isPitcher Boolean

  // MLB player info
  position String? // Primary position from MLB API (e.g., SS, CF, P)
  mlbTeam  String? // Current MLB team name

  // Hitting stats
  AB  Int?
  H   Int?
  R   Int?
  HR  Int?
  RBI Int?
  SB  Int?
  AVG Float?
  GS  Int? // Grand Slams

  // Pitching stats
  W    Int?
  SV   Int?
  K    Int?
  IP   Float?
  ER   Int?
  ERA  Float?
  WHIP Float?
  SO   Int? // Shut Outs

  draftDollars Int?
  isKeeper     Boolean @default(false)

  @@index([periodId, teamCode])
  @@index([periodId])
}

model HistoricalStanding {
  id       Int              @id @default(autoincrement())
  seasonId Int
  season   HistoricalSeason @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  teamCode String
  teamName String

  // Category scores for the SEASON
  R_score    Int?
  HR_score   Int?
  RBI_score  Int?
  SB_score   Int?
  AVG_score  Int?
  W_score    Int?
  SV_score   Int?
  K_score    Int?
  ERA_score  Int?
  WHIP_score Int?

  totalScore Int
  finalRank  Int

  @@unique([seasonId, teamCode])
  @@index([seasonId])
}

// ======================
//  League Invite System
// ======================

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED
}

model LeagueInvite {
  id        Int          @id @default(autoincrement())
  leagueId  Int
  email     String
  role      LeagueRole   @default(OWNER)
  invitedBy Int          // userId of commissioner who invited
  status    InviteStatus @default(PENDING)
  createdAt DateTime     @default(now())
  expiresAt DateTime

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  @@unique([leagueId, email])
  @@index([email])
  @@index([status])
}

model AuctionSession {
  id        Int      @id @default(autoincrement())
  leagueId  Int      @unique
  state     Json
  updatedAt DateTime @default(now()) @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
}

// ─── Snake Draft ───

model SnakeDraftSession {
  id        Int      @id @default(autoincrement())
  leagueId  Int      @unique
  state     Json     // { pickOrder, currentPickIndex, picks, timerExpiresAt, status, config }
  updatedAt DateTime @default(now()) @updatedAt

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
}

model DraftPick {
  id         Int      @id @default(autoincrement())
  leagueId   Int
  round      Int
  pickNum    Int      // Overall pick number (1-based)
  teamId     Int
  playerId   Int?     // null if skipped
  pickedAt   DateTime @default(now())
  isAutoPick Boolean  @default(false)

  league League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team   Team    @relation(fields: [teamId], references: [id])
  player Player? @relation(fields: [playerId], references: [id])

  @@unique([leagueId, round, pickNum])
  @@index([leagueId])
  @@index([teamId])
}

// ─── H2H Matchups ───

model Matchup {
  id           Int      @id @default(autoincrement())
  leagueId     Int
  week         Int      // Scoring period (1-based)
  periodId     Int?     // Links to Period for stats resolution
  teamAId      Int
  teamBId      Int
  result       Json?    // { teamA: { catWins, catLosses, catTies, points }, teamB: { ... } }
  isPlayoff    Boolean  @default(false)
  playoffRound Int?     // 1=quarterfinal, 2=semifinal, 3=final

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  period Period? @relation(fields: [periodId], references: [id])
  teamA  Team   @relation("matchupTeamA", fields: [teamAId], references: [id])
  teamB  Team   @relation("matchupTeamB", fields: [teamBId], references: [id])

  @@unique([leagueId, week, teamAId, teamBId])
  @@index([leagueId, week])
  @@index([periodId])
}

model AiInsight {
  id        Int      @id @default(autoincrement())
  type      String   // "weekly", "season_summary", etc.
  leagueId  Int
  teamId    Int
  weekKey   String   // e.g. "2026-W13" — dedup key for once-per-week generation
  data      Json     // { insights, overallGrade, mode, ... }
  createdAt DateTime @default(now())

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([type, leagueId, teamId, weekKey])
  @@index([teamId])
  @@index([leagueId])
  @@index([leagueId, type])
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  action       String   // e.g. TRADE_PROCESS, WAIVER_PROCESS, AUCTION_INIT, AUCTION_RESET, RULES_UPDATE
  resourceType String   // e.g. Trade, WaiverClaim, Auction, LeagueRule
  resourceId   String?  // ID of the affected resource (string for flexibility)
  metadata     Json?    // Additional context (JSON)
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model RosterEntry {
  id              Int      @id @default(autoincrement())
  year            Int      @default(2025)
  teamCode        String
  playerName      String
  position        String
  mlbTeam         String?
  acquisitionCost Int      @default(0)
  createdAt       DateTime @default(now())
}

// ======================
//  Player Values (Projected)
// ======================

model PlayerValue {
  id         Int      @id @default(autoincrement())
  leagueId   Int
  playerId   Int?
  mlbId      Int?
  playerName String
  position   String?
  value      Int
  source     String   @default("upload") // "upload", "manual"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  league League  @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  player Player? @relation(fields: [playerId], references: [id], onDelete: SetNull)

  @@unique([leagueId, playerName])
  @@index([leagueId])
  @@index([playerId])
}

// ======================
//  Watchlist — private player tracking per team
// ======================
model Watchlist {
  id        Int      @id @default(autoincrement())
  teamId    Int
  playerId  Int
  note      String?  @db.VarChar(200)
  tags      String[] @default([])     // "trade-target", "add-drop", "monitor"
  createdAt DateTime @default(now())

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId])
  @@index([teamId])
}

// ======================
//  Trading Block — public "available for trade" per team
// ======================
model TradingBlock {
  id        Int      @id @default(autoincrement())
  teamId    Int
  playerId  Int
  askingFor String?  @db.VarChar(200)  // "Need SP", "Looking for SB"
  createdAt DateTime @default(now())

  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([teamId, playerId])
  @@index([teamId])
}

// ======================
//  League Board — card-based async communication
// ======================
model BoardCard {
  id        Int      @id @default(autoincrement())
  leagueId  Int
  userId    Int?     // null for system-generated cards
  column    String   // "pinned", "activity", "trade_block", "banter"
  title     String
  body      String?  @db.Text
  type      String   // "user", "system", "trade", "waiver", "stat_alert", "award", "poll"
  metadata  Json?    // for polls: { options, votes }, for trades: { tradeId }, etc.
  pinned    Boolean  @default(false)
  periodId  Int?     // for auto-archiving by period
  expiresAt DateTime? // auto-expire (trade block posts expire at trade deadline)
  thumbsUp  Int      @default(0)
  thumbsDown Int     @default(0)
  createdAt DateTime @default(now())
  deletedAt DateTime? // soft delete

  league    League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])
  replies   BoardCardReply[]

  @@index([leagueId, column])
  @@index([leagueId, periodId])
  @@index([createdAt])
}

model BoardCardReply {
  id       Int      @id @default(autoincrement())
  cardId   Int
  userId   Int
  body     String
  createdAt DateTime @default(now())

  card     BoardCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id])

  @@index([cardId])
}

model BoardVote {
  id       Int    @id @default(autoincrement())
  cardId   Int
  userId   Int
  vote     String // "up" or "down"

  @@unique([cardId, userId])
}

// ======================
//  Product Board — platform-wide community board (not league-scoped)
// ======================

model ProductBoardCard {
  id         Int       @id @default(autoincrement())
  userId     Int
  channel    String    // "announcements", "marketplace", "general"
  title      String
  body       String?   @db.Text
  type       String    // "announcement", "league_listing", "free_agent", "discussion"
  metadata   Json?     // for listings: { sport, format, buyIn, spotsOpen }
  thumbsUp   Int       @default(0)
  thumbsDown Int       @default(0)
  createdAt  DateTime  @default(now())
  deletedAt  DateTime?

  user    User                @relation("ProductBoardCards", fields: [userId], references: [id])
  replies ProductBoardReply[]

  @@index([channel])
  @@index([createdAt])
}

model ProductBoardReply {
  id        Int      @id @default(autoincrement())
  cardId    Int
  userId    Int
  body      String
  createdAt DateTime @default(now())

  card ProductBoardCard @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user User             @relation("ProductBoardReplies", fields: [userId], references: [id])

  @@index([cardId])
}

// ======================
//  Push Notifications
// ======================

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NotificationPreference {
  id                   Int     @id @default(autoincrement())
  userId               Int     @unique
  tradeProposal        Boolean @default(true)
  tradeResult          Boolean @default(true)
  waiverResult         Boolean @default(true)
  lineupReminder       Boolean @default(true)
  commissionerAnnounce Boolean @default(true)
  boardReply           Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ======================
//  League Chat
// ======================

model ChatMessage {
  id        Int       @id @default(autoincrement())
  leagueId  Int
  userId    Int
  text      String    @db.Text
  type      String    @default("user") // "user", "system"
  metadata  Json?     // for system messages: { activityType, tradeId, etc. }
  createdAt DateTime  @default(now())
  deletedAt DateTime? // soft delete for moderation

  league League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@index([leagueId, createdAt])
}

model ChatReadCursor {
  id         Int      @id @default(autoincrement())
  userId     Int
  leagueId   Int
  lastReadId Int
  updatedAt  DateTime @updatedAt

  @@unique([userId, leagueId])
}
