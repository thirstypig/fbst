# Client env (Vite). Copy to client/.env for local dev.
# IMPORTANT: Do not commit client/.env

# Backend API base (the client/src/api.ts reads VITE_API_BASE)
VITE_API_BASE=http://localhost:4000/api

# PostHog analytics (optional — omit to disable tracking)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
